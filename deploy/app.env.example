# Configuration de l'APPLICATION dans le conteneur (env_file du docker-compose).
# Copiez ce fichier en `deploy/app.env` et ajustez les chemins.
#
# Le partage SMB « auditus » (PERSONNEL_PIERRE) est monté sur /mnt/auditus.
# Les anciens chemins UNC Windows deviennent donc des chemins Linux :
#   \\auditus.lan\PERSONNEL_PIERRE\03_GAMES\...  ->  /mnt/auditus/03_GAMES/...

# --- Obligatoire ---
FULL_CONTEXT_JSON_PATH=/mnt/auditus/03_GAMES/01_SKYRIM_NOLVUS/01_TAKENOTES/02_ABYSSIAELLE_v2/full_context.json
ENTRIES_DIR=/mnt/auditus/03_GAMES/01_SKYRIM_NOLVUS/01_TAKENOTES/02_ABYSSIAELLE_v2/entries

# Dossier des exports XML TakeNotes. Il vit désormais SUR AUDITUS : le PC de jeu
# y accède via une jonction de répertoire (voir DEPLOYMENT.md), de sorte que
# l'app (sur hiatus) et le jeu lisent/écrivent le même fichier sans copie manuelle.
TAKE_NOTES_EXPORT_DIR=/mnt/auditus/03_GAMES/01_SKYRIM_NOLVUS/01_TAKENOTES/TakeNotes

# --- Optionnel ---
METADATAS_DIR=/mnt/auditus/03_GAMES/01_SKYRIM_NOLVUS/01_TAKENOTES/02_ABYSSIAELLE_v2/metadatas
PDF_OUTPUT_PATH=/mnt/auditus/03_GAMES/01_SKYRIM_NOLVUS/01_TAKENOTES/02_ABYSSIAELLE_v2/export_pdf
PDF_EXPORT_FILE=ENTRIES
MAX_TOKENS_PER_ENTRY=1000

# Base d'archivage SQLite : dans le volume Docker persistant `tnfc-data`.
DATABASE_PATH=/data/injections.db
