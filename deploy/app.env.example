# Configuration de l'APPLICATION dans le conteneur (env_file du docker-compose).
# Copiez ce fichier en `deploy/app.env` et ajustez si besoin.
#
# Le dossier TakeNotes du partage est monté sur /mnt/TakeNotes. Il contient :
#   /mnt/TakeNotes/ExportChapter1.xml … ExportChapter5.xml   (export du jeu)
#   /mnt/TakeNotes/_APP/ENTRIES              (textes enrichis)
#   /mnt/TakeNotes/_APP/FULL_CONTEXT_JSON    (full_context.json)
#   /mnt/TakeNotes/_APP/METADATAS            (métadonnées, facultatif)
#   /mnt/TakeNotes/_APP/PDF_OUTPUT           (PDF générés)

# --- Obligatoire ---
FULL_CONTEXT_JSON_PATH=/mnt/TakeNotes/_APP/FULL_CONTEXT_JSON/full_context.json
ENTRIES_DIR=/mnt/TakeNotes/_APP/ENTRIES
# Dossier des exports XML TakeNotes = la racine du montage (là où le jeu écrit
# les ExportChapterN.xml). Le PC de jeu y accède via jonction (voir DEPLOYMENT.md).
TAKE_NOTES_EXPORT_DIR=/mnt/TakeNotes

# --- Optionnel ---
METADATAS_DIR=/mnt/TakeNotes/_APP/METADATAS
PDF_OUTPUT_PATH=/mnt/TakeNotes/_APP/PDF_OUTPUT
PDF_EXPORT_FILE=ENTRIES
MAX_TOKENS_PER_ENTRY=1000

# Base d'archivage SQLite : dans le volume Docker persistant `tnfc-data`.
DATABASE_PATH=/data/injections.db
