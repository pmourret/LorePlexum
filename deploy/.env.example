# Secrets d'infrastructure lus par Docker Compose (interpolation ${...} du
# docker-compose.yml). Copiez ce fichier en `deploy/.env` et renseignez-le.
# NE JAMAIS versionner le `.env` réel (il est ignoré par Git).

# Hôte SMB « auditus » (nom auditus.safe.home.arpa ou IP 192.168.1.138).
SMB_HOST=192.168.1.138

# Chemin complet monté (partage + sous-dossiers), en barres obliques, SANS le
# `//host` ni les antislashs UNC. C'est le dossier TakeNotes : il contient les
# ExportChapterN.xml du jeu ET le sous-dossier _APP (données de l'appli).
# = le même chemin que le device du /etc/fstab.
SMB_PATH=PERSONNEL_PIERRE/03_GAMES/01_SKYRIM_NOLVUS/03_TESV_ABYSSIAELLE/TakeNotes

# Fichier de credentials CIFS sur l'HÔTE (le même que celui du /etc/fstab).
# Contenu attendu (au moins) :
#   username=...
#   password=...
#   domain=...        # si nécessaire
# Le daemon Docker (root) le lit au moment du montage.
SMB_CREDENTIALS=/home/pmourret_adm/.smbcredentials

# Nom d'hôte exposé par Traefik (règle Host du routeur).
APP_HOST=tnfc.core.home.arpa
