# Secrets d'infrastructure lus par Docker Compose (interpolation ${...} du
# docker-compose.yml). Copiez ce fichier en `deploy/.env` et renseignez-le.
# NE JAMAIS versionner le `.env` réel (il est ignoré par Git).

# Hôte et partage SMB « auditus » (sans les antislashs UNC ; barres obliques).
SMB_HOST=auditus.safe.home.arpa
SMB_SHARE=PERSONNEL_PIERRE

# Identifiants d'accès au partage.
SMB_USER=pierre
SMB_PASSWORD=change-me

# Nom d'hôte exposé par Traefik (règle Host du routeur).
APP_HOST=tnfc.core.home.arpa
