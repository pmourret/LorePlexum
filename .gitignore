# --- Données locales du projet ---
/input/
/output/
# Base d'archivage des injections (SQLite, générée localement).
/data/
*.db

# --- Environnements virtuels ---
/venv/
/.venv/

# --- Secrets / configuration locale ---
# Le gabarit .env.struct reste versionné ; seul le .env réel est ignoré.
.env

# --- Déploiement Docker : secrets réels ignorés, gabarits .example versionnés ---
/deploy/.env
/deploy/app.env

# --- IDE ---
/.idea/

# --- Artefacts Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
